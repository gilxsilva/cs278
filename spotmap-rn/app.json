{
  "expo": {
    "name": "spot",
    "slug": "spotmap",
    "scheme": "gem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f3ee"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cs278.spotmap",
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_API_KEY"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f3ee"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.cs278.spotmap",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "extra": {
      "eas": {
        "projectId": "e4fb188d-1463-46dd-b537-ef9883db3a74"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/eec5fe7a-5e64-4070-b195-d3700d7d7d5d"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "owner": "evawanek"
  }
}
